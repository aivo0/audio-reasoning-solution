{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Observation reinterpretation output",
  "type": "object",
  "required": [
    "key_observations",
    "choice_analysis",
    "predicted_answer",
    "confidence",
    "alternative_interpretation",
    "reasoning"
  ],
  "additionalProperties": true,
  "properties": {
    "key_observations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "choice_analysis": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["support", "contradict", "plausibility"],
        "additionalProperties": true,
        "properties": {
          "support": {"type": "string"},
          "contradict": {"type": "string"},
          "plausibility": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "predicted_answer": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "alternative_interpretation": {"type": "string"},
    "reasoning": {"type": "string"}
  }
}
