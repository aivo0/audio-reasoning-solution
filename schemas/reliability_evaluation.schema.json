{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reliability evaluation output",
  "type": "object",
  "required": ["evaluated"],
  "additionalProperties": true,
  "properties": {
    "evaluated": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["observation", "source", "reliability", "grounding"],
        "additionalProperties": true,
        "properties": {
          "observation": {"type": "string"},
          "source": {"type": "string"},
          "reliability": {
            "type": "string",
            "enum": ["evidence_based", "speculative", "potentially_hallucinated"]
          },
          "grounding": {"type": "string"}
        }
      }
    }
  }
}
